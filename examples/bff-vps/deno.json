{
	"imports": {
		"@jayobado/hono-kit": "jsr:@jayobado/hono-kit@^0.4",
		"hono": "npm:hono@^4.12.0",
		"zod": "npm:zod@^3.24.0"
	},
	"tasks": {
		"dev": "MODE=dev deno run -A --watch src/main.ts",
		"start": "deno run -A src/main.ts",
		"build": "deno run -A scripts/build.ts"
	},
	"compilerOptions": {
		"strict": true
	}
}